{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build: API",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/CITL.WebApi/CITL.WebApi.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Run: API",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/src/CITL.WebApi/CITL.WebApi.csproj",
        "--launch-profile",
        "https"
      ],
      "isBackground": true,
      "problemMatcher": {
        "owner": "csharp",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Building.*$",
          "endsPattern": "^.*Now listening on:.*$"
        }
      }
    },
    {
      "label": "Run: Frontend",
      "type": "process",
      "command": "npm",
      "args": [
        "run",
        "dev",
        "--",
        "--open"
      ],
      "windows": {
        "command": "npm.cmd"
      },
      "linux": {
        "command": "npm"
      },
      "osx": {
        "command": "npm"
      },
      "options": {
        "cwd": "${workspaceFolder}/src/CITL.Web"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*$",
          "endsPattern": "^.*(Local:|ready in).*https://localhost:5173.*$"
        }
      }
    }
  ]
}
