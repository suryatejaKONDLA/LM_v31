# ─────────────────────────────────────────────────────────────
# CITL.Web — Environment Variable Template
# ─────────────────────────────────────────────────────────────
#
# HOW TO USE:
#   1. Copy this file to create your environment-specific files:
#        .env.development   → used when running   `npm run dev`
#        .env.production    → used when running   `npm run build`
#
#   2. Fill in the values below for each environment.
#
#   3. NEVER commit .env.development or .env.production.
#      They are listed in .gitignore.
#      Only this template (.env.example) is version-controlled.
#
# VITE CONVENTION:
#   All variables prefixed with VITE_ are exposed to client code
#   via import.meta.env. Never put secrets here — everything is
#   bundled into the final JS and visible in the browser.
#
# ─────────────────────────────────────────────────────────────

# API server base URL (include trailing slash)
# Must match the URL where CITL.WebApi is running.
# Example: https://localhost:7001/
VITE_API_BASE_URL=

# Client-side routing base path.
# Use "/" when the app is deployed at the domain root.
# Use "/myapp/" when deployed under a sub-path (e.g. https://example.com/myapp/).
VITE_BASE_PATH=/

# Tenant identifier — sent in the X-Tenant-Id header on every API request.
# Must match a key in the backend's MultiTenancy.TenantMappings configuration.
# Check appsettings.json → MultiTenancy → TenantMappings for valid values.
# Example: CITLPOS, CITLOGO, CITLAI
VITE_CLIENT_NAME=
