<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <rewrite>
      <rules>
        <!-- Brotli precompressed -->
        <rule name="Serve Brotli" stopProcessing="true">
          <match url="^(.+)\.(js|css|wasm)$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTP_ACCEPT_ENCODING}" pattern="br" />
            <add input="{APPL_PHYSICAL_PATH}{R:0}.br" matchType="IsFile" />
          </conditions>
          <action type="Rewrite" url="{R:0}.br" />
          <serverVariables>
            <set name="HTTP_X_ORIGINAL_EXT" value="{R:2}" />
            <set name="HTTP_X_COMPRESS_TYPE" value="br" />
          </serverVariables>
        </rule>

        <!-- Gzip precompressed fallback -->
        <rule name="Serve Gzip" stopProcessing="true">
          <match url="^(.+)\.(js|css|wasm)$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTP_ACCEPT_ENCODING}" pattern="gzip" />
            <add input="{APPL_PHYSICAL_PATH}{R:0}.gz" matchType="IsFile" />
          </conditions>
          <action type="Rewrite" url="{R:0}.gz" />
          <serverVariables>
            <set name="HTTP_X_ORIGINAL_EXT" value="{R:2}" />
            <set name="HTTP_X_COMPRESS_TYPE" value="gzip" />
          </serverVariables>
        </rule>

        <!-- React Router fallback -->
        <rule name="React Routes" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="index.html" />
        </rule>
      </rules>

      <outboundRules>
        <!-- Content-Encoding -->
        <rule name="Set Encoding BR" preCondition="IsBrotli">
          <match serverVariable="RESPONSE_Content-Encoding" pattern=".*" />
          <action type="Rewrite" value="br" />
        </rule>
        <rule name="Set Encoding Gzip" preCondition="IsGzip">
          <match serverVariable="RESPONSE_Content-Encoding" pattern=".*" />
          <action type="Rewrite" value="gzip" />
        </rule>

        <!-- Vary header -->
        <rule name="Add Vary Header" preCondition="HasOriginalExt">
          <match serverVariable="RESPONSE_Vary" pattern=".*" />
          <action type="Rewrite" value="Accept-Encoding" />
        </rule>

        <!-- Content-Type JS -->
        <rule name="Fix JS Content-Type" preCondition="IsJS">
          <match serverVariable="RESPONSE_Content-Type" pattern=".*" />
          <action type="Rewrite" value="application/javascript" />
        </rule>
        <!-- Content-Type CSS -->
        <rule name="Fix CSS Content-Type" preCondition="IsCSS">
          <match serverVariable="RESPONSE_Content-Type" pattern=".*" />
          <action type="Rewrite" value="text/css" />
        </rule>
        <!-- Content-Type WASM -->
        <rule name="Fix WASM Content-Type" preCondition="IsWASM">
          <match serverVariable="RESPONSE_Content-Type" pattern=".*" />
          <action type="Rewrite" value="application/wasm" />
        </rule>

        <preConditions>
          <preCondition name="IsBrotli">
            <add input="{HTTP_X_COMPRESS_TYPE}" pattern="^br$" />
          </preCondition>
          <preCondition name="IsGzip">
            <add input="{HTTP_X_COMPRESS_TYPE}" pattern="^gzip$" />
          </preCondition>
          <preCondition name="HasOriginalExt">
            <add input="{HTTP_X_ORIGINAL_EXT}" pattern=".+" />
          </preCondition>
          <preCondition name="IsJS">
            <add input="{HTTP_X_ORIGINAL_EXT}" pattern="^js$" />
          </preCondition>
          <preCondition name="IsCSS">
            <add input="{HTTP_X_ORIGINAL_EXT}" pattern="^css$" />
          </preCondition>
          <preCondition name="IsWASM">
            <add input="{HTTP_X_ORIGINAL_EXT}" pattern="^wasm$" />
          </preCondition>
        </preConditions>
      </outboundRules>
    </rewrite>

    <staticContent>
      <remove fileExtension=".woff" />
      <remove fileExtension=".woff2" />
      <remove fileExtension=".json" />
      <remove fileExtension=".webp" />
      <remove fileExtension=".avif" />
      <remove fileExtension=".webmanifest" />
      <remove fileExtension=".wasm" />
      <remove fileExtension=".br" />
      <remove fileExtension=".gz" />
      <mimeMap fileExtension=".woff" mimeType="font/woff" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <mimeMap fileExtension=".webp" mimeType="image/webp" />
      <mimeMap fileExtension=".avif" mimeType="image/avif" />
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
      <mimeMap fileExtension=".wasm" mimeType="application/wasm" />
      <mimeMap fileExtension=".br" mimeType="application/octet-stream" />
      <mimeMap fileExtension=".gz" mimeType="application/octet-stream" />
    </staticContent>

    <urlCompression doStaticCompression="false" doDynamicCompression="false" />

    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="Content-Security-Policy" value="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; worker-src 'self' blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://www.citl.co.in https://api.ipify.org wss: blob:; frame-src 'self' blob:; frame-ancestors 'self'; base-uri 'self'; form-action 'self';" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <add name="Permissions-Policy" value="geolocation=(self), accelerometer=(), camera=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()" />
        <add name="X-DNS-Prefetch-Control" value="on" />
      </customHeaders>
    </httpProtocol>

    <caching>
      <profiles>
        <add extension=".html" policy="DisableCache" kernelCachePolicy="DisableCache" />
      </profiles>
    </caching>

  </system.webServer>

  <location path="assets">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="DisableCache" />
      </staticContent>
      <httpProtocol>
        <customHeaders>
          <remove name="Cache-Control" />
          <add name="Cache-Control" value="public, max-age=31536000, immutable" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>

  <location path="fonts">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="DisableCache" />
      </staticContent>
      <httpProtocol>
        <customHeaders>
          <remove name="Cache-Control" />
          <add name="Cache-Control" value="public, max-age=31536000, immutable" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>

  <location path="images">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="DisableCache" />
      </staticContent>
      <httpProtocol>
        <customHeaders>
          <remove name="Cache-Control" />
          <add name="Cache-Control" value="public, max-age=31536000, immutable" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>

  <location path="index.html">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="DisableCache" />
      </staticContent>
      <httpProtocol>
        <customHeaders>
          <remove name="Cache-Control" />
          <add name="Cache-Control" value="no-cache, no-store, must-revalidate" />
          <add name="Pragma" value="no-cache" />
          <add name="Expires" value="0" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>

</configuration>
