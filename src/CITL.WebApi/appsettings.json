{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "Quartz": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:HH:mm:ss.fff} [{Level:u3}] [{CorrelationId}] [{TenantId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [],
    "AllowedMethods": [],
    "AllowedHeaders": [],
    "ExposedHeaders": [
      "X-Correlation-Id",
      "X-Request-Id"
    ],
    "AllowCredentials": true
  },
  "ConnectionStrings": {
    "Redis": "localhost:6379,abortConnect=false,connectTimeout=5000,syncTimeout=5000"
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "CITL.WebApi",
    "Audience": "CITL.Client",
    "AccessTokenExpirationMinutes": 30,
    "RefreshTokenExpirationDays": 30,
    "ClockSkewMinutes": 1
  },
  "OpenTelemetry": {
    "Endpoint": ""
  },
  "ApiDocumentation": {
    "Version": "v1",
    "Title": "CITL API",
    "Description": "CITL Multi-Tenant SaaS Platform API — Clean Architecture, Dapper, SQL Server",
    "ContactName": "Suryateja Kondla",
    "ContactEmail": "",
    "ContactUrl": "",
    "UseMultipleApiGroups": true
  },
  "FileStorage": {
    "Provider": "R2",
    "LocalBasePath": "D:\\Storage",
    "LocalQuotaGB": 20,
    "R2Endpoint": "",
    "R2AccessKey": "",
    "R2SecretKey": "",
    "R2BucketName": "",
    "R2PublicDomain": "",
    "SignedUrlExpiryMinutes": 15,
    "AllowedExtensions": [
      "jpg",
      "jpeg",
      "png",
      "gif",
      "bmp",
      "svg",
      "webp",
      "ico",
      "tiff",
      "tif",
      "pdf",
      "doc",
      "docx",
      "xls",
      "xlsx",
      "ppt",
      "pptx",
      "odt",
      "ods",
      "odp",
      "rtf",
      "txt",
      "csv",
      "json",
      "xml",
      "zip",
      "rar",
      "7z",
      "tar",
      "gz",
      "mp3",
      "mp4",
      "wav",
      "avi",
      "mov",
      "wmv",
      "flv",
      "mkv",
      "webm",
      "ogg"
    ]
  },
  "MultiTenancy": {
    "ConnectionStringTemplate": "Server=.;Database={dbName};User Id=sa;Password=;Trusted_Connection=false;Encrypt=true;TrustServerCertificate=true;MultipleActiveResultSets=true;Connection Timeout=30;Min Pool Size=5;Max Pool Size=100;ConnectRetryCount=3;ConnectRetryInterval=10;Application Name=CITL",
    "TenantMappings": {
      "CITLPOS": "CITLPOS",
      "CITLOGO": "CITLOGO",
      "CITLAI": "CITLAI"
    }
  },
  "HealthChecks": {
    "ProcessMemory": {
      "ThresholdMB": 1024
    }
  }
}
